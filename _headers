# Оптимальные headers для производительности и безопасности

# HTML - не кешировать, всегда проверять на сервере
/*.html
  Cache-Control: public, max-age=0, must-revalidate
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  X-XSS-Protection: 1; mode=block
  Referrer-Policy: strict-origin-when-cross-origin

# CSS и JavaScript - кешировать на 1 год (файлы имеют хеши в имени)
/css/*
  Cache-Control: public, max-age=31536000, immutable
  X-Content-Type-Options: nosniff

/js/*
  Cache-Control: public, max-age=31536000, immutable
  X-Content-Type-Options: nosniff

# Изображения - кешировать на 1 год
/uploads/*
  Cache-Control: public, max-age=31536000, immutable
  X-Content-Type-Options: nosniff

# SVG иконки - кешировать на 1 год
/icons/*
  Cache-Control: public, max-age=31536000, immutable
  X-Content-Type-Options: nosniff

# Favicon и manifest - кешировать на 30 дней
/favicon.svg
  Cache-Control: public, max-age=2592000
  X-Content-Type-Options: nosniff

/apple-touch-icon.svg
  Cache-Control: public, max-age=2592000
  X-Content-Type-Options: nosniff

/site.webmanifest
  Cache-Control: public, max-age=2592000
  Content-Type: application/manifest+json
  X-Content-Type-Options: nosniff

# Sitemap и robots - кешировать на 7 дней
/sitemap.xml
  Cache-Control: public, max-age=604800
  Content-Type: application/xml
  X-Content-Type-Options: nosniff

/robots.txt
  Cache-Control: public, max-age=604800
  Content-Type: text/plain
  X-Content-Type-Options: nosniff

# Все остальное - кешировать на 1 час
/*
  Cache-Control: public, max-age=3600
  X-Content-Type-Options: nosniff
